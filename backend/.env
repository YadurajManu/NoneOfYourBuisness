# Database connection for Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/medlifecycle?schema=public"

# Redis connection
REDIS_HOST="localhost"
REDIS_PORT=6379

# App configuration
PORT=3100
JWT_SECRET="your-development-secret-key-keep-it-safe"

# Local Storage
STORAGE_PATH="./data/uploads"
ENCRYPTION_KEY="32-char-long-secret-encryption-key"
